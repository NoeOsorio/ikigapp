# Copy this file to .env.local and fill in your Firebase project values.
# Find these in the Firebase console → Project Settings → Your apps → SDK setup.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# OpenAI API key for AI Ikigai generation (gpt-4o-mini).
# Warning: visible in browser bundle. Move to a server/Cloud Function for production.
VITE_OPENAI_API_KEY=
